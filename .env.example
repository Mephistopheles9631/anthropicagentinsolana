# Shredstream gRPC endpoint
SHREDSTREAM_GRPC_TARGET=localhost:50051

# Generated protobuf modules and symbols
GRPC_MESSAGES_MODULE=shredstream_pb2
GRPC_STUB_MODULE=shredstream_pb2_grpc
GRPC_STUB_CLASS=ShredstreamProxyStub
GRPC_STREAM_METHOD=SubscribeEntries
GRPC_REQUEST_CLASS=SubscribeEntriesRequest
GRPC_REQUEST_JSON={}

# Entry decoder
ENTRY_DECODER_PATH=tools/entry_decoder/target/release/entry_decoder
ENTRY_DECODER_TIMEOUT_SECONDS=8

# Program IDs to track (fill in with exact values)
PROGRAM_ID_PUMPFUN=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
PROGRAM_ID_PUMPSWAP=pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA
PROGRAM_ID_RAYDIUM=
PROGRAM_IDS_RAYDIUM=CAMMCzo5YL8w4VFF8KVHrK22GGUsp5VTaW7grrKgrWqK,CPMMoo8L3F4NbTegBCKVNunggL7H1ZpdTHKxQB5qKP1C,LanMV9sAd7wArD4vJFi2qDdfnVhFxYSUg6eADduJ3uj
PROGRAM_ID_METEORA=cpamdpZCGKUy5JxQXB4dcpGPiikHawvSWAd6mEn1sGG
PROGRAM_IDS_METEORA=
PROGRAM_ID_METEORA_DAMM_V2=cpamdpZCGKUy5JxQXB4dcpGPiikHawvSWAd6mEn1sGG
PROGRAM_ID_WHIRLPOOL=whirLbMiicVdio4qvUfM5KAg6Ct8VwpYzGff3uctyCc

# IDL source and optional explicit program-id mapping for IDLs that do not include address/programId.
IDL_DIR=idl
IDL_PROGRAM_ID_MAP_JSON={"MeteoraDAMMv2.json":"cpamdpZCGKUy5JxQXB4dcpGPiikHawvSWAd6mEn1sGG","whirlpool.json":"whirLbMiicVdio4qvUfM5KAg6Ct8VwpYzGff3uctyCc"}

# If true, startup fails when configured program IDs are missing from local IDLs.
VALIDATE_IDLS_ON_STARTUP=false

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_TABLE=shredstream_events

# Batching
BATCH_SIZE=250
FLUSH_INTERVAL_SECONDS=1.0

# Mint profiler
PROFILE_DELAY_MINUTES=5
PROFILE_MAX_AGE_MINUTES=240
PROFILE_CHECK_INTERVAL_SECONDS=60

# Claude / Anthropic — set API key to enable AI scoring
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_SCORE_THRESHOLD=0.70
CLAUDE_MAX_EXAMPLES=10
CLAUDE_RETRY_ATTEMPTS=3
CLAUDE_RETRY_MAX_WAIT_SECONDS=8
CLAUDE_ALERT_DEDUP_MINUTES=240

# Opportunity alert filters
OPPORTUNITY_MIN_CONFIDENCE=medium
OPPORTUNITY_MIN_UNIQUE_BUYERS_5M=0
OPPORTUNITY_MAX_WALLET_CONCENTRATION_5M=1.0

# DexScreener enrichment
DEXSCREENER_ENABLED=true
DEXSCREENER_BASE_URL=https://api.dexscreener.com/latest/dex/tokens
DEXSCREENER_TIMEOUT_SECONDS=8

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord notifications (optional)
DISCORD_WEBHOOK_URL=
